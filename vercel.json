{
  "version": 2,
  "rewrites": [
    {
      "source": "/npm/@clerk/(.*)",
      "destination": "https://cdn.jsdelivr.net/npm/@clerk/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://*.clerk.accounts.dev;"
        }
      ]
    }
  ]
}
